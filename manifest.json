{
  "manifest_version": 3,
  "name": "APK.tw & Bingfong 自動簽到",
  "version": "1.3",
  "description": "每日自動簽到 apk.tw 與 bingfong.com，可自訂簽到時間",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "*://apk.tw/*",
    "*://www.apk.tw/*",
    "*://bingfong.com/*",
    "*://www.bingfong.com/*",
    "https://github.com/*",
    "https://avatars.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://apk.tw/forum.php*",
        "*://www.apk.tw/forum.php*",
        "*://bingfong.com/forum.php*",
        "*://www.bingfong.com/forum.php*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "自動簽到設定"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
